// =============================================================================
// CarGlow — Prisma schema
// =============================================================================
// Postgres + Prisma. Designed for multi-tenant SaaS with workspaces.
// Run: pnpm db:generate && pnpm db:push
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  STAFF
  ADMIN
}

enum WorkspaceRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum Plan {
  TRIAL
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

enum VehicleStatus {
  DRAFT
  READY
  LISTED
  SOLD
  ARCHIVED
}

enum PhotoStatus {
  UPLOADED
  QUEUED
  PROCESSING
  ENHANCED
  FAILED
}

enum CreditReason {
  MONTHLY_GRANT
  PURCHASE
  ENHANCEMENT
  REFUND
  ADJUSTMENT
}

// ── AUTH (NextAuth.js) ───────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── CORE ─────────────────────────────────────────────────────────────────────

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  emailVerified     DateTime?
  name              String?
  image             String?
  password          String?
  locale            String   @default("en")
  role              UserRole @default(USER)
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  accounts          Account[]
  sessions          Session[]
  workspaceMembers  WorkspaceMember[]
  photosCreated     Photo[]
  auditLogs         AuditLog[]
}

model Workspace {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  logoUrl             String?
  plan                Plan     @default(TRIAL)
  planRenewsAt        DateTime?
  creditsRemaining    Int      @default(50)
  creditsPerMonth     Int      @default(50)
  vatNumber           String?
  billingAddress      Json?
  billingEmail        String?
  stripeCustomerId    String?  @unique
  stripeSubscriptionId String? @unique
  ssoEnabled          Boolean  @default(false)
  ssoDomain           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  members        WorkspaceMember[]
  invites        Invite[]
  vehicles       Vehicle[]
  photos         Photo[]
  folders        Folder[]
  tags           Tag[]
  styles         Style[]
  brandKits      BrandKit[]
  apiKeys        ApiKey[]
  webhooks       Webhook[]
  auditLogs      AuditLog[]
  creditTxs      CreditTransaction[]

  @@index([stripeCustomerId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(EDITOR)
  joinedAt    DateTime      @default(now())
  lastActiveAt DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Invite {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(EDITOR)
  token       String        @unique
  expiresAt   DateTime
  invitedBy   String?
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

// ── VEHICLES & MEDIA ─────────────────────────────────────────────────────────

model Vehicle {
  id            String        @id @default(cuid())
  workspaceId   String
  name          String
  vin           String?
  make          String?
  model         String?
  year          Int?
  mileage       Int?
  price         Decimal?      @db.Decimal(12,2)
  status        VehicleStatus @default(DRAFT)
  coverPhotoId  String?       @unique
  description   String?       @db.Text
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  coverPhoto Photo?    @relation("VehicleCover", fields: [coverPhotoId], references: [id])
  photos     Photo[]   @relation("VehiclePhotos")

  @@index([workspaceId])
  @@index([status])
}

model Folder {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  parentId    String?
  color       String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[]  @relation("FolderTree")
  photos    Photo[]

  @@index([workspaceId, parentId])
}

model Photo {
  id            String      @id @default(cuid())
  workspaceId   String
  vehicleId     String?
  folderId      String?
  sessionId     String?
  originalUrl   String
  enhancedUrl   String?
  thumbnailUrl  String?
  status        PhotoStatus @default(UPLOADED)
  styleUsed     String?
  toolsUsed     Json?       // array of {tool, params} pairs
  processingMs  Int?
  errorMessage  String?
  width         Int?
  height        Int?
  sizeBytes     Int?
  createdById   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?   @relation("VehiclePhotos", fields: [vehicleId], references: [id], onDelete: SetNull)
  folder         Folder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdBy      User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  vehicleCoverOf Vehicle?   @relation("VehicleCover")
  tags           PhotoTag[]
  creditTxs      CreditTransaction[]
  shareLinks     ShareLink[]

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([vehicleId])
  @@index([sessionId])
  @@index([status])
}

model Tag {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#FF8A3D")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  photos    PhotoTag[]

  @@unique([workspaceId, name])
}

model PhotoTag {
  photoId String
  tagId   String
  photo   Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([photoId, tagId])
}

// ── STYLES & BRAND ───────────────────────────────────────────────────────────

model Style {
  id           String   @id @default(cuid())
  name         String
  slug         String
  category     String   // Studio | Outdoor | Lifestyle | Premium | Custom
  thumbnailUrl String
  prompt       String?  @db.Text
  isCustom     Boolean  @default(false)
  workspaceId  String?  // nullable for global styles
  popularity   Int      @default(0)
  createdAt    DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([category])
}

model BrandKit {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String   @default("Default")
  logoUrl         String?
  plateFrameUrl   String?
  watermarkUrl    String?
  primaryColor    String   @default("#FF8A3D")
  secondaryColor  String?
  defaultStyleId  String?
  defaultPlateMask Boolean @default(true)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ── API / WEBHOOKS / AUDIT ──────────────────────────────────────────────────

model ApiKey {
  id          String   @id @default(cuid())
  workspaceId String
  label       String
  hashedKey   String   @unique
  prefix      String   // first 8 chars for display
  scopes      String[] // ["photos:read", "photos:write", ...]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Webhook {
  id          String   @id @default(cuid())
  workspaceId String
  url         String
  events      String[] // ["photo.enhanced", "vehicle.created", ...]
  secret      String
  isActive    Boolean  @default(true)
  failureCount Int     @default(0)
  lastFiredAt DateTime?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String?
  action      String   // photo.enhanced, member.invited, billing.updated, ...
  target      String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
}

// ── BILLING & SHARING ───────────────────────────────────────────────────────

model CreditTransaction {
  id              String       @id @default(cuid())
  workspaceId     String
  delta           Int          // positive for grant/purchase, negative for spend
  balanceAfter    Int
  reason          CreditReason
  photoId         String?
  stripeInvoiceId String?
  notes           String?
  createdAt       DateTime     @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  photo     Photo?    @relation(fields: [photoId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
}

model ShareLink {
  id        String   @id @default(cuid())
  slug      String   @unique
  photoId   String?
  vehicleId String?
  expiresAt DateTime?
  password  String?  // hashed if set
  viewCount Int      @default(0)
  createdBy String?
  createdAt DateTime @default(now())

  photo Photo? @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([slug])
}
